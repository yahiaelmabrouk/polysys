# Application
NODE_ENV=development
PORT=3004
APP_NAME=enrollment-service

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/enrollment_db?schema=public"

# JWT (must match Auth Service access secret)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here

# Redis (used for distributed locks + caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Inter-service
INTERNAL_SECRET=internal_service_secret_key
AUTH_SERVICE_URL=http://localhost:3001
STUDENTS_SERVICE_URL=http://localhost:3002
COURSES_SERVICE_URL=http://localhost:3003
GRADES_SERVICE_URL=http://localhost:3005

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Enrollment Business Rules
MIN_FULL_TIME_CREDITS=12
MAX_STANDARD_CREDITS=18
MAX_OVERLOAD_CREDITS=24
WAITLIST_RESERVATION_TTL_HOURS=48
ENROLLMENT_LOCK_TTL_SECONDS=10
ENABLE_PREREQUISITE_CHECK=true
ENABLE_SCHEDULE_CONFLICT_CHECK=false
