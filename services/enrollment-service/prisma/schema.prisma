// Enrollment Service Prisma schema
// Owns: enrollments, waitlists, registration windows, course capacity
// snapshots, enrollment audit logs, and reservations.
// Does NOT own: auth users, student profiles, course catalog, grades,
// schedules/timetables, finance/billing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EnrollmentStatus {
  PENDING
  ENROLLED
  WAITLISTED
  DROPPED
  WITHDRAWN
  COMPLETED
  FAILED

  @@map("enrollment_status")
}

enum EnrollmentSource {
  SELF_SERVICE
  ADMIN
  SYSTEM

  @@map("enrollment_source")
}

enum GradingOption {
  LETTER
  PASS_FAIL

  @@map("grading_option")
}

enum WaitlistStatus {
  ACTIVE
  PROMOTED
  REMOVED
  EXPIRED

  @@map("waitlist_status")
}

enum RegistrationRoleScope {
  STUDENT
  ADMIN
  ALL

  @@map("registration_role_scope")
}

enum AuditAction {
  ENROLLED
  DROPPED
  WITHDRAWN
  OVERRIDE
  PROMOTED_WAITLIST
  STATUS_CHANGED
  CAPACITY_CHANGED
  WINDOW_CHANGED

  @@map("audit_action")
}

// ─── Enrollments ──────────────────────────────────────────────────────────────

model Enrollment {
  id               String           @id @default(uuid())
  studentId        String           @map("student_id")
  courseId         String           @map("course_id")
  academicTerm     String           @map("academic_term")
  sectionCode      String?          @map("section_code")
  enrolledAt       DateTime         @default(now()) @map("enrolled_at")
  status           EnrollmentStatus @default(PENDING)
  source           EnrollmentSource @default(SELF_SERVICE)
  creditsSnapshot  Decimal          @default(0) @map("credits_snapshot") @db.Decimal(5, 2)
  gradingOption    GradingOption    @default(LETTER) @map("grading_option")
  droppedAt        DateTime?        @map("dropped_at")
  dropReason       String?          @map("drop_reason")
  overrideReason   String?          @map("override_reason")
  createdByUserId  String?          @map("created_by_user_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  auditLogs        EnrollmentAuditLog[]

  // Active enrollment must be unique per (student, course, term).
  // Inactive rows (dropped/withdrawn/failed) are allowed to coexist
  // for history; uniqueness for the "active" state is enforced via a
  // partial unique index added in the SQL migration.
  @@index([studentId])
  @@index([courseId])
  @@index([academicTerm])
  @@index([status])
  @@index([courseId, academicTerm])
  @@index([studentId, academicTerm])
  @@index([studentId, courseId, academicTerm])
  @@map("enrollments")
}

// ─── Waitlists ────────────────────────────────────────────────────────────────

model Waitlist {
  id            String         @id @default(uuid())
  studentId     String         @map("student_id")
  courseId      String         @map("course_id")
  academicTerm  String         @map("academic_term")
  sectionCode   String?        @map("section_code")
  position      Int
  priorityScore Int            @default(0) @map("priority_score")
  joinedAt      DateTime       @default(now()) @map("joined_at")
  status        WaitlistStatus @default(ACTIVE)
  notifiedAt    DateTime?      @map("notified_at")
  expiresAt     DateTime?      @map("expires_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([studentId])
  @@index([courseId, academicTerm, position])
  @@index([status])
  @@index([studentId, status])
  @@map("waitlists")
}

// ─── Registration Windows ─────────────────────────────────────────────────────

model RegistrationWindow {
  id                String                @id @default(uuid())
  academicTerm      String                @map("academic_term")
  roleScope         RegistrationRoleScope @default(STUDENT) @map("role_scope")
  opensAt           DateTime              @map("opens_at")
  closesAt          DateTime              @map("closes_at")
  lateAddDeadline   DateTime?             @map("late_add_deadline")
  dropDeadline      DateTime              @map("drop_deadline")
  withdrawDeadline  DateTime              @map("withdraw_deadline")
  isActive          Boolean               @default(true) @map("is_active")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  @@unique([academicTerm, roleScope])
  @@index([academicTerm])
  @@index([isActive])
  @@map("registration_windows")
}

// ─── Capacity Snapshots ───────────────────────────────────────────────────────

model CourseCapacitySnapshot {
  id             String   @id @default(uuid())
  courseId       String   @map("course_id")
  academicTerm   String   @map("academic_term")
  sectionCode    String?  @map("section_code")
  capacityTotal  Int      @default(0) @map("capacity_total")
  seatsTaken     Int      @default(0) @map("seats_taken")
  seatsReserved  Int      @default(0) @map("seats_reserved")
  waitlistCount  Int      @default(0) @map("waitlist_count")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([courseId, academicTerm, sectionCode])
  @@index([courseId, academicTerm])
  @@map("course_capacity_snapshots")
}

// ─── Enrollment Audit Logs ────────────────────────────────────────────────────

model EnrollmentAuditLog {
  id            String      @id @default(uuid())
  enrollmentId  String?     @map("enrollment_id")
  actorUserId   String?     @map("actor_user_id")
  action        AuditAction
  metadataJson  Json?       @map("metadata_json")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  createdAt     DateTime    @default(now()) @map("created_at")

  enrollment    Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([enrollmentId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("enrollment_audit_logs")
}

// ─── Generic Audit Log (for non-enrollment admin actions) ─────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
