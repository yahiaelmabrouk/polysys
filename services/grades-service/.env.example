# Application
NODE_ENV=development
PORT=3005
APP_NAME=grades-service

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/grades_db?schema=public"

# JWT (must match Auth Service access secret)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here

# Redis (optional caching + locks for result publication)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Inter-service
INTERNAL_SECRET=internal_service_secret_key
AUTH_SERVICE_URL=http://localhost:3001
STUDENTS_SERVICE_URL=http://localhost:3002
COURSES_SERVICE_URL=http://localhost:3003
ENROLLMENT_SERVICE_URL=http://localhost:3004

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Grading business rules
DEFAULT_PASS_PERCENTAGE=50
ALLOW_TEACHER_PUBLISH=false
TRANSCRIPT_NUMBER_PREFIX=TR
RESULT_PUBLISH_LOCK_TTL_SECONDS=30
