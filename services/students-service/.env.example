# Students Service Environment Variables

# Application
NODE_ENV=development
PORT=3002
APP_NAME=students-service

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/students_db?schema=public"

# JWT (must match Auth Service access secret)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here

# Redis (optional caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Inter-service
INTERNAL_SECRET=internal_service_secret_key
AUTH_SERVICE_URL=http://localhost:3001

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Business Rules
ATTENDANCE_LOCK_DAYS=7
LOW_ATTENDANCE_THRESHOLD=75
