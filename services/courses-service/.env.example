# Application
NODE_ENV=development
PORT=3003
APP_NAME=courses-service

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/courses_db?schema=public"

# JWT (must match Auth Service access secret)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars_here

# Redis (optional caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Inter-service
INTERNAL_SECRET=internal_service_secret_key
AUTH_SERVICE_URL=http://localhost:3001

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Catalog Business Rules
MIN_COURSE_CREDITS=1
MAX_COURSE_CREDITS=10
ALLOW_DECIMAL_CREDITS=false
