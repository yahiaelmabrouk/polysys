{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/departments/*": ["src/departments/*"],
      "@/subjects/*": ["src/subjects/*"],
      "@/courses/*": ["src/courses/*"],
      "@/prerequisites/*": ["src/prerequisites/*"],
      "@/teacher-assignments/*": ["src/teacher-assignments/*"],
      "@/catalog/*": ["src/catalog/*"],
      "@/common/*": ["src/common/*"],
      "@/config/*": ["src/config/*"],
      "@/guards/*": ["src/guards/*"],
      "@/strategies/*": ["src/strategies/*"],
      "@/database/*": ["src/database/*"],
      "@/events/*": ["src/events/*"],
      "@/internal/*": ["src/internal/*"]
    }
  }
}
